// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      String   @default("individual") // individual, legal, government, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
  alerts    Alert[]
  logs      AuditLog[]
}

model Asset {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // email, phone, domain
  value       String
  status      String   @default("monitored")
  lastChecked DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Alert {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  asset            String
  source           String
  severity         String
  date             String
  exposedDataTypes String[]
  recommendations  String[]
  description      String?
  status           String   @default("pending")
  createdAt        DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  ip        String?
  resource  String?
  status    Int?
  createdAt DateTime @default(now())
}
